// Equipos
const equipmentTypes = [
  {
    title: "Elevadores de Pasajeros",
    subtitle: "Comercial y Corporativo",
    description: "Soluciones para edificios de oficinas, hospitales, hoteles y centros comerciales. Capacidad de 6 a 21 personas, velocidades de hasta 4 m/s.",
