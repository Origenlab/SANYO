    href: "/equipos/escaleras-electricas",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="28" height="28" aria-hidden="true"><line x1="3" y1="21" x2="21" y2="3"/><polyline points="9 3 21 3 21 15"/></svg>`,
