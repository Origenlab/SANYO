---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Elevadores en Querétaro — Instalación y Mantenimiento | Sanyo"
  description="Servicio de elevadores y escaleras eléctricas en Querétaro, El Marqués, Corregidora y San Juan del Río. Instalación, mantenimiento, NOM-147. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/zonas/">Zonas</a> › Querétaro</div>
      <span class="page-badge">Querétaro</span>
      <h1 class="page-hero__title">Elevadores en <span class="text-accent">Querétaro</span></h1>
      <p class="page-hero__subtitle">
        Atendemos el estado de Querétaro con servicio de instalación, mantenimiento y modernización de 
        elevadores. Zona de alto crecimiento industrial, comercial y residencial.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar en Querétaro →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Zona bajío — <span class="text-accent">crecimiento acelerado</span></h2>
          <p class="body-text">
            Querétaro se ha consolidado como uno de los polos de desarrollo industrial y residencial más 
            importantes de México. Los nuevos desarrollos verticales, centros comerciales y parques 
            industriales demandan soluciones de <strong>transporte vertical de alta calidad</strong>.
          </p>
          <p class="body-text">
            En Sanyo atendemos Querétaro desde nuestra red CDMX con técnicos especializados que cubren 
            la capital, El Marqués, Corregidora, San Juan del Río y municipios aledaños.
          </p>
          <h3 class="subsection-title">Servicios disponibles en Querétaro</h3>
          <ul class="advantages-list">
            <li>✅ Instalación de elevadores nuevos de todas las marcas</li>
            <li>✅ Contratos de mantenimiento preventivo y correctivo</li>
            <li>✅ Modernización de elevadores existentes</li>
            <li>✅ Certificación NOM-147-SCFI</li>
            <li>✅ Escaleras eléctricas para centros comerciales</li>
            <li>✅ Plataformas de accesibilidad</li>
          </ul>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Municipios con cobertura</h3>
            <ul class="check-list">
              <li>Querétaro capital</li>
              <li>El Marqués</li>
              <li>Corregidora</li>
              <li>San Juan del Río</li>
              <li>Pedro Escobedo</li>
              <li>Zona industrial</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Sectores clave en QRO</h3>
            <ul class="check-list-light">
              <li>Parques industriales automotrices</li>
              <li>Centros comerciales (Antea, Uptown)</li>
              <li>Desarrollos residenciales de lujo</li>
              <li>Hospitales y clínicas privadas</li>
              <li>Hoteles y centros de convenciones</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Proyecto en Querétaro?"
        text="Somos tu aliado en transporte vertical para la zona bajío. Asesoría técnica, instalación certificada y mantenimiento continuo."
        buttonText="Cotizar en Querétaro →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza servicio en Querétaro" subtitle="Describe tu proyecto en la zona bajío." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .advantages-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .advantages-list li { font-size: var(--text-base); color: var(--color-text); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .check-list, .check-list-light { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .check-list-light li { font-size: var(--text-sm); color: rgba(255,255,255,.9); }
  .check-list-light li::before { content: "• "; color: var(--color-accent); }
</style>
