---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";

const alcaldias = [
  "Álvaro Obregón","Azcapotzalco","Benito Juárez","Coyoacán","Cuajimalpa","Cuauhtémoc",
  "Gustavo A. Madero","Iztacalco","Iztapalapa","La Magdalena Contreras","Miguel Hidalgo",
  "Milpa Alta","Tláhuac","Tlalpan","Venustiano Carranza","Xochimilco"
];
---
<PageLayout
  title="Elevadores en CDMX — Servicio en las 16 Alcaldías | Sanyo"
  description="Servicio de elevadores y escaleras eléctricas en todas las alcaldías de CDMX. Respuesta en 90 min. Mantenimiento, instalación, modernización. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/zonas/">Zonas</a> › CDMX</div>
      <span class="page-badge">Ciudad de México</span>
      <h1 class="page-hero__title">Elevadores en <span class="text-accent">CDMX</span> — 16 alcaldías</h1>
      <p class="page-hero__subtitle">
        Base de operaciones principal. Técnicos disponibles en todas las alcaldías de Ciudad de México 
        con tiempo de respuesta en emergencias menor a 90 minutos.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar en CDMX →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Cobertura completa en <span class="text-accent">Ciudad de México</span></h2>
          <p class="body-text">
            CDMX es nuestra zona de operación principal con <strong>más de 800 equipos bajo contrato de 
            mantenimiento</strong>. Contamos con equipos técnicos distribuidos estratégicamente en zonas 
            norte, sur, oriente y poniente para garantizar tiempos de respuesta inmediatos.
          </p>
          <p class="body-text">
            Atendemos desde elevadores residenciales en Polanco y Coyoacán hasta escaleras eléctricas 
            en centros comerciales de Santa Fe, Perisur y centros de negocios en Reforma e Insurgentes.
          </p>
          <h3 class="subsection-title">Alcaldías con cobertura</h3>
          <div class="alcaldias-grid">
            {alcaldias.map(a => (
              <span class="alcaldia-chip">{a}</span>
            ))}
          </div>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Datos CDMX</h3>
            <ul class="check-list">
              <li>800+ equipos bajo contrato</li>
              <li>Respuesta: &lt;90 min emergencia</li>
              <li>Técnicos en 4 zonas</li>
              <li>Refacciones en stock local</li>
              <li>24/7/365</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Zonas de alta demanda</h3>
            <ul class="check-list-light">
              <li>Polanco / Lomas — Residencial premium</li>
              <li>Santa Fe — Corporativo</li>
              <li>Reforma — Oficinas</li>
              <li>Coyoacán — Residencial</li>
              <li>Iztapalapa — Industrial</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Necesitas servicio en CDMX?"
        text="Somos la empresa con mayor presencia en la Ciudad de México. Técnicos certificados a menos de 30 minutos de tu ubicación."
        buttonText="Cotizar servicio CDMX →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza servicio en CDMX" subtitle="Indica tu alcaldía y el tipo de servicio para una propuesta rápida." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .alcaldias-grid { display: flex; flex-wrap: wrap; gap: var(--space-sm); }
  .alcaldia-chip { background: #f8f9fa; border: 1px solid var(--color-border-light); color: var(--color-text); font-size: var(--text-sm); padding: var(--space-sm) var(--space-md); border-radius: var(--radius-full); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .check-list, .check-list-light { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .check-list-light li { font-size: var(--text-sm); color: rgba(255,255,255,.9); }
  .check-list-light li::before { content: "• "; color: var(--color-accent); }
</style>
