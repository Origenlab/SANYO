---
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
---

<PageLayout
  title="Contacto — Sanyo Elevadores y Escaleras Eléctricas CDMX"
  description="Contáctanos para servicio de elevadores y escaleras eléctricas en CDMX. WhatsApp, teléfono, correo. Respuesta en menos de 2 horas en Ciudad de México."
>
  <!-- Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="page-hero__content">
        <span class="page-badge">Contacto</span>
        <h1 class="page-hero__title">Estamos listos para <span class="text-accent">atenderte ahora</span></h1>
        <p class="page-hero__subtitle">
          Servicio disponible 24/7 para emergencias. Para cotizaciones y consultas, respondemos en menos de 2 horas en horario laboral.
        </p>
      </div>
    </div>
  </section>

  <!-- Contacto grid -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Datos de contacto -->
        <div class="contact-info">
          <h2 class="contact-info__title">Canales de atención</h2>

          <div class="contact-channels">
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, necesito información sobre elevadores`}
               target="_blank" rel="noopener"
               class="channel-card channel-card--wa">
              <div class="channel-card__icon">💬</div>
              <div class="channel-card__content">
                <strong>WhatsApp</strong>
                <span>Respuesta inmediata</span>
                <em>{SITE.contact.phone}</em>
              </div>
              <div class="channel-card__arrow">→</div>
            </a>

            <a href={`tel:${SITE.contact.phoneRaw}`} class="channel-card">
              <div class="channel-card__icon">📞</div>
              <div class="channel-card__content">
                <strong>Teléfono</strong>
                <span>Lun–Sáb 8am–8pm</span>
                <em>{SITE.contact.phone}</em>
              </div>
              <div class="channel-card__arrow">→</div>
            </a>

            <a href={`mailto:${SITE.contact.email}`} class="channel-card">
              <div class="channel-card__icon">✉️</div>
              <div class="channel-card__content">
                <strong>Correo electrónico</strong>
                <span>Respuesta en 24h hábiles</span>
                <em>{SITE.contact.email}</em>
              </div>
              <div class="channel-card__arrow">→</div>
            </a>
          </div>

          <!-- Ubicación / Cobertura -->
          <div class="coverage-box">
            <h3 class="coverage-box__title">📍 Cobertura de servicio</h3>
            <ul class="coverage-list">
              <li>Ciudad de México — Todas las alcaldías</li>
              <li>Estado de México — Municipios conurbados</li>
              <li>Querétaro y zona bajío</li>
              <li>Cobertura nacional en 32 estados</li>
            </ul>
          </div>

          <!-- Horarios -->
          <div class="hours-box">
            <h3 class="hours-box__title">🕐 Horarios</h3>
            <div class="hours-grid">
              <div>
                <strong>Oficina</strong>
                <p>Lunes a Viernes: 8:00 – 19:00 hrs</p>
                <p>Sábados: 9:00 – 15:00 hrs</p>
              </div>
              <div>
                <strong>Emergencias</strong>
                <p>24 horas, 7 días a la semana</p>
                <p>365 días del año</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Formulario de contacto -->
        <div class="contact-form-wrapper">
          <h2 class="form-title">Envíanos un mensaje</h2>
          <p class="form-subtitle">Completa el formulario y te contactamos a la brevedad.</p>

          <form class="contact-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre">Nombre completo *</label>
                <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre">
              </div>
              <div class="form-group">
                <label for="telefono">Teléfono *</label>
                <input type="tel" id="telefono" name="telefono" required placeholder="55 1234 5678">
              </div>
            </div>
            <div class="form-group">
              <label for="email">Correo electrónico *</label>
              <input type="email" id="email" name="email" required placeholder="tu@empresa.com">
            </div>
            <div class="form-group">
              <label for="empresa">Empresa / Proyecto</label>
              <input type="text" id="empresa" name="empresa" placeholder="Nombre de tu empresa o proyecto">
            </div>
            <div class="form-group">
              <label for="asunto">Asunto *</label>
              <select id="asunto" name="asunto" required>
                <option value="">Selecciona el motivo</option>
                <option value="cotizacion">Solicitar cotización</option>
                <option value="mantenimiento">Mantenimiento de equipo</option>
                <option value="emergencia">Emergencia (equipo detenido)</option>
                <option value="modernizacion">Modernización</option>
                <option value="instalacion">Instalación nueva</option>
                <option value="certificacion">Certificación NOM-147</option>
                <option value="otro">Otro</option>
              </select>
            </div>
            <div class="form-group">
              <label for="mensaje">Mensaje *</label>
              <textarea id="mensaje" name="mensaje" rows="5" required
                placeholder="Describe tu necesidad: tipo de equipo, marca, número de pisos, ubicación..."></textarea>
            </div>
            <button type="submit" class="submit-btn">Enviar mensaje</button>
            <p class="form-note">Al enviar este formulario aceptas nuestro <a href="/privacidad">aviso de privacidad</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Mapa placeholder -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="map-title">Zona de cobertura principal</h2>
      <p class="map-subtitle">CDMX y Estado de México — Atención en menos de 90 minutos</p>
      <div class="map-embed">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d240906.73870987!2d-99.30868899999999!3d19.390519799999997!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce0026db097507%3A0x54061076265ee841!2sCiudad%20de%20M%C3%A9xico%2C%20CDMX!5e0!3m2!1ses-419!2smx!4v1700000000000"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Zona de cobertura Sanyo Elevadores CDMX"
        ></iframe>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .page-hero {
    background: var(--color-primary);
    color: #fff;
    padding-block: var(--space-4xl);
  }
  .page-hero__content { max-width: 720px; }
  .page-hero__title {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.2;
    margin-block: var(--space-lg);
    color: #fff;
  }
  .page-hero__subtitle {
    font-size: var(--text-lg);
    color: rgba(255,255,255,.85);
    line-height: 1.7;
  }
  .page-badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    padding: var(--space-xs) var(--space-lg);
    border-radius: var(--radius-full);
  }
  .text-accent { color: var(--color-accent); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-4xl);
    align-items: start;
  }
  @media(max-width: 900px) { .contact-grid { grid-template-columns: 1fr; } }
  .contact-info__title, .form-title {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    margin-block-end: var(--space-xl);
  }
  .contact-channels { display: flex; flex-direction: column; gap: var(--space-md); margin-block-end: var(--space-2xl); }
  .channel-card {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    background: #fff;
    border: 2px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition-fast), transform var(--transition-fast);
  }
  .channel-card:hover { border-color: var(--color-accent); transform: translateY(-2px); }
  .channel-card--wa { border-color: #25D366; }
  .channel-card--wa:hover { border-color: #128C7E; }
  .channel-card__icon { font-size: 2rem; flex-shrink: 0; }
  .channel-card__content { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .channel-card__content strong { font-weight: 700; color: var(--color-primary); font-size: var(--text-base); }
  .channel-card__content span { font-size: var(--text-sm); color: var(--color-text-light); }
  .channel-card__content em { font-size: var(--text-sm); font-style: normal; color: var(--color-accent); font-weight: 600; }
  .channel-card__arrow { color: var(--color-text-light); font-size: 1.25rem; }
  .coverage-box, .hours-box {
    background: var(--color-primary);
    color: #fff;
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    margin-block-end: var(--space-lg);
  }
  .coverage-box__title, .hours-box__title {
    font-size: var(--text-base);
    font-weight: 700;
    margin-block-end: var(--space-md);
    color: #fff;
  }
  .coverage-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .coverage-list li { font-size: var(--text-sm); color: rgba(255,255,255,.85); }
  .coverage-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .hours-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  .hours-grid strong { display: block; color: var(--color-accent); font-size: var(--text-sm); margin-block-end: var(--space-xs); }
  .hours-grid p { font-size: var(--text-sm); color: rgba(255,255,255,.85); margin: 0; }
  .contact-form-wrapper {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-lg);
  }
  .form-subtitle { font-size: var(--text-sm); color: var(--color-text-light); margin-block-end: var(--space-xl); }
  .contact-form { display: flex; flex-direction: column; gap: var(--space-lg); }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  @media(max-width: 560px) { .form-row { grid-template-columns: 1fr; } }
  .form-group { display: flex; flex-direction: column; gap: var(--space-xs); }
  .form-group label { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); }
  .form-group input, .form-group select, .form-group textarea {
    padding: var(--space-md);
    border: 2px solid var(--color-border-light);
    border-radius: var(--radius-md);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: border-color var(--transition-fast);
    font-family: var(--font-sans);
  }
  .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
    border-color: var(--color-accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(230,57,70,.12);
  }
  .submit-btn {
    background: var(--color-accent);
    color: #fff;
    border: none;
    font-size: var(--text-base);
    font-weight: 700;
    padding: var(--space-lg) var(--space-2xl);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--transition-fast), transform var(--transition-fast);
  }
  .submit-btn:hover { background: var(--color-accent-hover); transform: translateY(-2px); }
  .form-note { font-size: var(--text-xs); color: var(--color-text-light); }
  .form-note a { color: var(--color-accent); }
  .map-title { font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); text-align: center; }
  .map-subtitle { font-size: var(--text-base); color: var(--color-text-light); text-align: center; margin-block: var(--space-sm) var(--space-2xl); }
  .map-embed { border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-lg); }
</style>
