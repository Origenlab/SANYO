---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Plataforma Salvaescaleras para Discapacitados — CDMX | Sanyo"
  description="Plataformas salvaescaleras y elevadores verticales para personas con discapacidad en CDMX. NOM-247-SSA1. Instalación sin obra mayor. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/plataformas/">Plataformas</a> › Accesibilidad</div>
      <span class="page-badge">Plataforma accesible</span>
      <h1 class="page-hero__title">Plataformas salvaescaleras — <span class="text-accent">accesibilidad sin barreras</span></h1>
      <p class="page-hero__subtitle">
        Instalamos plataformas verticales y salvaescaleras para garantizar el acceso de personas con 
        discapacidad en edificios donde no es viable instalar un elevador convencional.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar plataforma accesible →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Soluciones de <span class="text-accent">accesibilidad universal</span></h2>
          <p class="body-text">
            Las <strong>plataformas salvaescaleras</strong> son la alternativa más económica y de menor impacto 
            constructivo para garantizar la accesibilidad en edificios existentes. Se instalan sobre escaleras 
            ya construidas sin necesidad de obras civiles mayores.
          </p>
          <p class="body-text">
            Ofrecemos dos tipos principales: <strong>plataformas inclinadas</strong> (salvaescaleras sobre 
            el plano de la escalera) y <strong>plataformas verticales</strong> (elevación directa entre niveles 
            en espacios reducidos).
          </p>
          <h3 class="subsection-title">Tipos de plataformas accesibles</h3>
          <div class="types-grid">
            <div class="type-card">
              <h4>Plataforma inclinada</h4>
              <p>Se monta sobre los barandales de la escalera existente. Ideal para escaleras de 1 a 3 tramos. Instalación en 1-2 días.</p>
            </div>
            <div class="type-card">
              <h4>Plataforma vertical</h4>
              <p>Elevación directa hasta 3 m de altura. Se instala en el hueco de la escalera o en un área adyacente. Requiere mínima obra.</p>
            </div>
          </div>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Características clave</h3>
            <ul class="check-list">
              <li>Capacidad: 300–400 kg</li>
              <li>Plataforma para silla de ruedas</li>
              <li>Control unilateral o bilateral</li>
              <li>Barandas plegables automáticas</li>
              <li>Cumplimiento NOM-247-SSA1</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Subsidios disponibles</h3>
            <p>Para edificios de dependencias de gobierno y servicios de salud pueden existir subsidios federales y del GDF para instalación de equipos de accesibilidad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Necesitas accesibilidad en tu edificio?"
        text="Hacemos una evaluación técnica gratuita de tu espacio para recomendarte la plataforma más adecuada. También tramitamos los permisos necesarios."
        buttonText="Evaluación gratuita →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza tu plataforma salvaescaleras" subtitle="Describe el espacio y el tipo de escalera para recibir una propuesta." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; max-width: 22ch; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .types-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg); }
  .type-card { background: #f8f9fa; padding: var(--space-xl); border-radius: var(--radius-lg); border-left: 3px solid var(--color-accent); }
  .type-card h4 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-sm); }
  .type-card p { font-size: var(--text-sm); color: var(--color-text-light); line-height: 1.6; }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .info-card--accent p { font-size: var(--text-sm); color: rgba(255,255,255,.9); line-height: 1.7; }
  .check-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
</style>
