---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Escaleras Eléctricas para Centros Comerciales — CDMX | Sanyo"
  description="Escaleras eléctricas para centros comerciales, tiendas departamentales y plazas en CDMX. Alto tráfico, operación 24/7. Marcas Mitsubishi, Kone, Otis. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/escaleras-electricas/">Escaleras</a> › Comercial</div>
      <span class="page-badge">Escalera comercial</span>
      <h1 class="page-hero__title">Escaleras eléctricas para <span class="text-accent">centros comerciales</span></h1>
      <p class="page-hero__subtitle">
        Sistemas de alto tráfico diseñados para la operación continua en centros comerciales, tiendas departamentales, 
        plazas y supermercados. Millones de usos anuales sin falla.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar escalera comercial →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Escaleras para <span class="text-accent">alto tráfico</span></h2>
          <p class="body-text">
            Las escaleras eléctricas comerciales están diseñadas para soportar el tráfico intenso de centros 
            comerciales con millones de usuarios al año. A diferencia de los modelos estándar, incorporan 
            <strong>componentes reforzados</strong>, sistemas de lubricación automática y diagnóstico remoto 
            para minimizar el tiempo de inactividad.
          </p>
          <h3 class="subsection-title">Especificaciones estándar</h3>
          <div class="specs-grid">
            <div class="spec-item"><strong>Ancho:</strong> 600, 800 o 1,000 mm</div>
            <div class="spec-item"><strong>Velocidad:</strong> 0.5 m/s (estándar)</div>
            <div class="spec-item"><strong>Ángulo:</strong> 30° o 35°</div>
            <div class="spec-item"><strong>Altura:</strong> Hasta 12 m por unidad</div>
            <div class="spec-item"><strong>Capacidad:</strong> Hasta 9,000 personas/hora</div>
            <div class="spec-item"><strong>Operación:</strong> Continua 24/7</div>
          </div>
          <h3 class="subsection-title">Características premium</h3>
          <ul class="advantages-list">
            <li>✅ Sistema de monitoreo remoto (IoT)</li>
            <li>✅ Lubricación automática de cadena</li>
            <li>✅ Arranque suave para mayor comodidad</li>
            <li>✅ Modo ahorro de energía en horas de bajo tráfico</li>
            <li>✅ Parada de emergencia automática por obstáculo</li>
          </ul>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Marcas disponibles</h3>
            <ul class="check-list">
              <li>Mitsubishi Electric</li>
              <li>Kone</li>
              <li>Otis</li>
              <li>Schindler</li>
              <li>ThyssenKrupp</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Nuestro servicio incluye</h3>
            <ul class="check-list-light">
              <li>Diseño del proyecto</li>
              <li>Tramitación de permisos</li>
              <li>Instalación certificada</li>
              <li>Contrato de mantenimiento</li>
              <li>Servicio de emergencia 24/7</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Planeas instalar escaleras en tu plaza o tienda?"
        text="Nuestro equipo ha instalado escaleras eléctricas en más de 50 centros comerciales en CDMX y Estado de México. Solicita asesoría técnica sin costo."
        buttonText="Solicitar cotización →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza tu escalera eléctrica comercial" subtitle="Dinos las dimensiones y el tipo de proyecto para enviarte una propuesta." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; max-width: 22ch; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .spec-item { background: #f8f9fa; padding: var(--space-md); border-radius: var(--radius-md); font-size: var(--text-sm); color: var(--color-text); border-left: 3px solid var(--color-accent); }
  .spec-item strong { color: var(--color-primary); }
  .advantages-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .advantages-list li { font-size: var(--text-base); color: var(--color-text); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .check-list, .check-list-light { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .check-list-light li { font-size: var(--text-sm); color: rgba(255,255,255,.9); }
  .check-list-light li::before { content: "✓ "; color: var(--color-accent); }
</style>
