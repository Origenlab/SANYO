---
import PageLayout from "@layouts/PageLayout.astro";

const articles = [
  {
    title: "¿Cuánto cuesta instalar un elevador en CDMX? Guía de precios 2025",
    excerpt: "Desglosamos los costos reales de instalar un elevador en Ciudad de México: equipo, obra civil, permisos y mantenimiento anual.",
    href: "/blog/cuanto-cuesta-instalar-elevador-cdmx",
    date: "2025-03-01",
    tag: "Costos",
  },
  {
    title: "Mantenimiento de elevadores: qué dice la NOM-147-SCFI",
    excerpt: "Todo lo que debes saber sobre la norma NOM-147-SCFI y las obligaciones legales de mantenimiento de elevadores en México.",
    href: "/blog/mantenimiento-elevador-norma-nom-147",
    date: "2025-02-15",
    tag: "Normatividad",
  },
  {
    title: "Elevador sin cuarto de máquinas (MRL): la guía completa",
    excerpt: "Qué es un elevador MRL, cómo funciona, ventajas sobre el sistema convencional y cuándo elegirlo para tu proyecto.",
    href: "/blog/elevador-sin-cuarto-maquinas-mrl-guia",
    date: "2025-02-01",
    tag: "Tecnología",
  },
  {
    title: "Escaleras eléctricas para centros comerciales: guía de selección",
    excerpt: "Cómo elegir la escalera eléctrica correcta para tu centro comercial: capacidad, ancho, velocidad y marcas recomendadas.",
    href: "/blog/escalera-electrica-centro-comercial-guia",
    date: "2025-01-20",
    tag: "Escaleras",
  },
  {
    title: "Elevador residencial para casa: precio y opciones en México",
    excerpt: "Guía completa para instalar un elevador en tu casa: tipos, precios, espacio necesario y recomendaciones para México.",
    href: "/blog/elevador-residencial-casa-precio-mexico",
    date: "2025-01-10",
    tag: "Residencial",
  },
];
---

<PageLayout
  title="Blog — Artículos sobre Elevadores y Escaleras Eléctricas | Sanyo"
  description="Artículos, guías y consejos sobre elevadores, escaleras eléctricas, normatividad NOM-147 y transporte vertical en México. Blog de Sanyo Elevadores."
>
  <section class="page-hero">
    <div class="container">
      <span class="page-badge">Blog Sanyo</span>
      <h1 class="page-hero__title">Artículos y guías sobre <span class="text-accent">elevadores en México</span></h1>
      <p class="page-hero__subtitle">
        Recursos, guías de precios, normatividad y tecnología sobre elevadores y escaleras eléctricas. 
        Información útil para propietarios, administradores y profesionales de la construcción.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="articles-grid">
        {articles.map(a => (
          <a href={a.href} class="article-card">
            <div class="article-card__header">
              <span class="article-card__tag">{a.tag}</span>
              <!-- fecha eliminada: regla OrigenLab -->
            </div>
            <h2 class="article-card__title">{a.title}</h2>
            <p class="article-card__excerpt">{a.excerpt}</p>
            <span class="article-card__link">Leer artículo →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); }
  .text-accent { color: var(--color-accent); }
  .section { padding-block: var(--space-4xl); }
  .articles-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
  @media(max-width: 768px) { .articles-grid { grid-template-columns: 1fr; } }
  .article-card {
    background: #fff;
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: border-color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-fast);
  }
  .article-card:hover { border-color: var(--color-accent); transform: translateY(-4px); box-shadow: var(--shadow-lg); }
  .article-card__header { display: flex; justify-content: space-between; align-items: center; }
  .article-card__tag { background: var(--color-primary); color: #fff; font-size: var(--text-xs); font-weight: 700; padding: 2px var(--space-sm); border-radius: var(--radius-sm); text-transform: uppercase; }
  .article-card__date { font-size: var(--text-xs); color: var(--color-text-light); }
  .article-card__title { font-size: var(--text-xl); font-weight: 800; color: var(--color-primary); line-height: 1.3; }
  .article-card__excerpt { font-size: var(--text-sm); color: var(--color-text-light); line-height: 1.7; flex-grow: 1; }
  .article-card__link { font-size: var(--text-sm); font-weight: 700; color: var(--color-accent); }
</style>
