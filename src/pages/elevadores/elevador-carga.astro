---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Elevadores de Carga Industrial — Montacargas CDMX | Sanyo"
  description="Elevadores de carga y montacargas industriales de 500 kg a 5,000 kg en CDMX. Instalación para bodegas, almacenes y fábricas. Certificados NOM-147-SCFI. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/elevadores/">Elevadores</a> › Carga industrial</div>
      <span class="page-badge">Elevadores de carga</span>
      <h1 class="page-hero__title">Montacargas y elevadores de carga <span class="text-accent">industriales</span></h1>
      <p class="page-hero__subtitle">
        Soluciones robustas para mover mercancía y equipo pesado entre pisos. Capacidades de 500 kg hasta 5,000 kg. 
        Instalación en bodegas, almacenes, fábricas y centros de distribución en CDMX y toda la República.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar montacargas →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Elevadores de carga para <span class="text-accent">uso industrial</span></h2>
          <p class="body-text">
            Los <strong>elevadores de carga</strong> o montacargas son equipos de transporte vertical diseñados 
            para mover mercancía, pallets, maquinaria y equipo pesado entre los distintos niveles de un edificio 
            industrial o comercial.
          </p>
          <p class="body-text">
            A diferencia de los elevadores de pasajeros, los elevadores de carga tienen <strong>estructuras reforzadas</strong>, 
            puertas de mayor apertura y sistemas de seguridad especiales para tolerar condiciones de trabajo 
            continuas y cargas pesadas.
          </p>
          <h3 class="subsection-title">Especificaciones técnicas</h3>
          <div class="specs-grid">
            <div class="spec-item"><strong>Capacidad:</strong> 500 kg – 5,000 kg</div>
            <div class="spec-item"><strong>Velocidad:</strong> 0.25 – 0.63 m/s</div>
            <div class="spec-item"><strong>Cabina:</strong> Hasta 4m × 3m (personalizable)</div>
            <div class="spec-item"><strong>Puertas:</strong> Batientes, corredizas o enrollables</div>
            <div class="spec-item"><strong>Piso:</strong> Diamantado antiderrapante o liso</div>
            <div class="spec-item"><strong>Sistema:</strong> Hidráulico o eléctrico según altura</div>
          </div>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Aplicaciones industriales</h3>
            <ul class="check-list">
              <li>Bodegas y almacenes</li>
              <li>Centros de distribución</li>
              <li>Plantas manufactureras</li>
              <li>Talleres de producción</li>
              <li>Restaurantes y cocinas</li>
              <li>Tiendas de autoservicio</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Ventaja Sanyo</h3>
            <p>Instalamos elevadores de carga con <strong>acero estructural galvanizado</strong> y <strong>motores trifásicos</strong> de alta eficiencia. Garantía de 2 años en componentes principales.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Cuánto cuesta un montacargas industrial?"
        text="El precio depende de la capacidad de carga, dimensiones de la cabina, número de paradas y tipo de puerta. Solicita tu cotización y recibe una propuesta en menos de 24 horas."
        buttonText="Solicitar cotización →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza tu elevador de carga" subtitle="Dinos cuántos kg necesitas mover y te recomendamos la mejor solución." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; max-width: 20ch; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .specs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-md); }
  .spec-item { background: #f8f9fa; padding: var(--space-md); border-radius: var(--radius-md); font-size: var(--text-sm); color: var(--color-text); border-left: 3px solid var(--color-accent); }
  .spec-item strong { color: var(--color-primary); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .info-card--accent p { font-size: var(--text-sm); color: rgba(255,255,255,.9); line-height: 1.7; }
  .info-card--accent strong { color: #fff; }
  .check-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
</style>
