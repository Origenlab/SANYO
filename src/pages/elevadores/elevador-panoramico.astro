---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Elevadores Panorámicos de Cristal — CDMX México | Sanyo"
  description="Elevadores panorámicos de vidrio para hoteles, centros comerciales y lobbies de lujo. Diseños personalizados, iluminación LED. Instalación en CDMX. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/elevadores/">Elevadores</a> › Panorámico</div>
      <span class="page-badge">Elevadores panorámicos</span>
      <h1 class="page-hero__title">Elevadores panorámicos de <span class="text-accent">cristal y diseño premium</span></h1>
      <p class="page-hero__subtitle">
        Convierte tu elevador en un elemento arquitectónico. Los elevadores panorámicos de vidrio son la 
        opción premium para hoteles, centros comerciales, lobbies corporativos y proyectos de lujo.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar elevador panorámico →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Elevadores que <span class="text-accent">impresionan</span></h2>
          <p class="body-text">
            Los <strong>elevadores panorámicos</strong> combinan funcionalidad y diseño arquitectónico. La cabina 
            de vidrio templado permite a los usuarios disfrutar de las vistas del edificio durante el recorrido, 
            creando una experiencia única que refuerza la imagen de tu establecimiento.
          </p>
          <p class="body-text">
            En Sanyo instalamos elevadores panorámicos con <strong>vidrio laminado de seguridad</strong>, 
            <strong>iluminación LED personalizable</strong> y estructura de acero inoxidable de alta calidad. 
            Cada proyecto es diseñado a medida para integrarse perfectamente al espacio arquitectónico.
          </p>
          <h3 class="subsection-title">Opciones de personalización</h3>
          <ul class="advantages-list">
            <li>✅ Vidrio templado o laminado (6mm–12mm)</li>
            <li>✅ Iluminación LED RGB o blanca cálida/fría</li>
            <li>✅ Estructura en acero inoxidable o acero pintado</li>
            <li>✅ Piso de mármol, madera o acero</li>
            <li>✅ Cabina curvada o rectangular</li>
            <li>✅ Integración con BMS del edificio</li>
          </ul>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Ideal para</h3>
            <ul class="check-list">
              <li>Hoteles de 4 y 5 estrellas</li>
              <li>Centros comerciales</li>
              <li>Lobbies corporativos</li>
              <li>Residencias de lujo</li>
              <li>Restaurantes y bares</li>
              <li>Museos y galerías</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Especificaciones</h3>
            <ul class="spec-list">
              <li>Capacidad: 4–20 personas</li>
              <li>Sistema: Hidráulico o MRL</li>
              <li>Cristal: Templado/laminado 8mm</li>
              <li>Cert.: NOM-147-SCFI</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Quieres un elevador que destaque?"
        text="Diseñamos el elevador panorámico perfecto para tu proyecto. Nuestros arquitectos e ingenieros trabajan juntos para crear una solución que combine estética y funcionalidad."
        buttonText="Solicitar diseño personalizado →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza tu elevador panorámico" subtitle="Cuéntanos sobre tu proyecto arquitectónico. Creamos soluciones a medida." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; max-width: 22ch; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .advantages-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .advantages-list li { font-size: var(--text-base); color: var(--color-text); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .check-list, .spec-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .spec-list li { font-size: var(--text-sm); color: rgba(255,255,255,.9); }
  .spec-list li::before { content: "• "; color: var(--color-accent); }
</style>
