---
import PageLayout from "@layouts/PageLayout.astro";
import SectionCTA from "@components/SectionCTA.astro";
import QuoteForm from "@components/QuoteForm.astro";
---
<PageLayout
  title="Elevadores para Discapacitados — Accesibilidad NOM-247-SSA1 | Sanyo"
  description="Elevadores y plataformas para personas con discapacidad en CDMX. Cumplimiento NOM-247-SSA1. Botonera Braille, cabina amplia, puertas automáticas. Cotiza gratis."
>
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb"><a href="/">Inicio</a> › <a href="/elevadores/">Elevadores</a> › Accesibilidad</div>
      <span class="page-badge">Accesibilidad universal</span>
      <h1 class="page-hero__title">Elevadores accesibles — <span class="text-accent">NOM-247-SSA1</span></h1>
      <p class="page-hero__subtitle">
        Soluciones de transporte vertical que garantizan accesibilidad universal para personas con discapacidad 
        motriz, visual o auditiva. Cumplimiento total de la NOM-247-SSA1 y normatividad CONAPRED.
      </p>
      <div class="hero-ctas">
        <a href="/cotizar" class="btn-primary">Cotizar solución accesible →</a>
        <a href="https://wa.me/525520780102" target="_blank" class="btn-secondary">💬 WhatsApp</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="two-col">
        <div>
          <h2 class="section-title-left">Accesibilidad universal — <span class="text-accent">obligatoria por ley</span></h2>
          <p class="body-text">
            La <strong>NOM-247-SSA1</strong> establece los requisitos de accesibilidad para personas con discapacidad 
            en edificaciones públicas y privadas. Los elevadores accesibles son obligatorios en hospitales, 
            escuelas, oficinas gubernamentales y edificios de uso público en México.
          </p>
          <p class="body-text">
            En Sanyo diseñamos e instalamos elevadores que cumplen con todas las especificaciones de accesibilidad: 
            <strong>cabinas amplias para sillas de ruedas</strong>, botoneras con escritura Braille, indicadores 
            auditivos de piso y puertas automáticas de apertura amplia.
          </p>
          <h3 class="subsection-title">Características NOM-247-SSA1</h3>
          <ul class="advantages-list">
            <li>✅ Cabina mínima 1,100 × 1,400 mm para silla de ruedas</li>
            <li>✅ Puertas automáticas de 900 mm mínimo de apertura</li>
            <li>✅ Botonera con Braille y contraste visual</li>
            <li>✅ Pasamanos a 900 mm de altura en 3 paredes</li>
            <li>✅ Indicadores auditivos de piso (voz sintetizada)</li>
            <li>✅ Espejo en pared posterior para maniobra en reversa</li>
            <li>✅ Borde fotoeléctrico sensible en puertas</li>
            <li>✅ Nivelación precisa con el piso (±5 mm)</li>
          </ul>
        </div>
        <div class="info-sidebar">
          <div class="info-card">
            <h3>Normas que cumplimos</h3>
            <ul class="check-list">
              <li>NOM-247-SSA1 — Accesibilidad</li>
              <li>NOM-147-SCFI — Elevadores</li>
              <li>Ley General para la Inclusión</li>
              <li>CDMX — Reglamento de Construcción</li>
            </ul>
          </div>
          <div class="info-card info-card--accent">
            <h3>Edificios obligados</h3>
            <ul class="check-list-light">
              <li>Hospitales y clínicas</li>
              <li>Escuelas y universidades</li>
              <li>Edificios de gobierno</li>
              <li>Centros comerciales</li>
              <li>Hoteles de cualquier categoría</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt">
    <div class="container">
      <SectionCTA
        title="¿Tu edificio cumple con la NOM-247-SSA1?"
        text="Realizamos auditorías de accesibilidad sin costo. Detectamos incumplimientos y proponemos soluciones para que tu edificio sea 100% accesible y cumpla con la ley."
        buttonText="Solicitar auditoría de accesibilidad →"
        buttonHref="/cotizar"
        variant="primary"
      />
    </div>
  </section>

  <div id="cotizador">
    <QuoteForm title="Cotiza tu solución de accesibilidad" subtitle="Diseñamos la solución de transporte vertical accesible para tu edificio." />
  </div>
</PageLayout>

<style>
  .page-hero { background: var(--color-primary); color: #fff; padding-block: var(--space-4xl); }
  .breadcrumb { font-size: var(--text-sm); color: rgba(255,255,255,.7); margin-block-end: var(--space-lg); }
  .breadcrumb a { color: rgba(255,255,255,.7); text-decoration: none; }
  .page-badge { display: inline-block; background: var(--color-accent); color: #fff; font-size: var(--text-xs); font-weight: 700; text-transform: uppercase; letter-spacing: .05em; padding: var(--space-xs) var(--space-lg); border-radius: var(--radius-full); margin-block-end: var(--space-md); }
  .page-hero__title { font-size: var(--text-4xl); font-weight: 800; line-height: 1.2; margin-block: var(--space-lg); color: #fff; max-width: 22ch; }
  .page-hero__subtitle { font-size: var(--text-lg); color: rgba(255,255,255,.85); line-height: 1.7; max-width: 55ch; margin-block-end: var(--space-xl); }
  .text-accent { color: var(--color-accent); }
  .hero-ctas { display: flex; gap: var(--space-md); flex-wrap: wrap; }
  .btn-primary { background: var(--color-accent); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); }
  .btn-secondary { background: rgba(255,255,255,.15); color: #fff; font-weight: 700; padding: var(--space-md) var(--space-xl); border-radius: var(--radius-md); text-decoration: none; font-size: var(--text-base); border: 1px solid rgba(255,255,255,.3); }
  .section { padding-block: var(--space-4xl); }
  .section--alt { background: #f8f9fa; }
  .two-col { display: grid; grid-template-columns: 1.5fr 1fr; gap: var(--space-4xl); align-items: start; }
  @media(max-width: 900px) { .two-col { grid-template-columns: 1fr; } }
  .section-title-left { font-size: var(--text-3xl); font-weight: 800; color: var(--color-primary); line-height: 1.2; margin-block-end: var(--space-xl); }
  .body-text { font-size: var(--text-base); color: var(--color-text); line-height: 1.8; margin-block-end: var(--space-md); }
  .subsection-title { font-size: var(--text-xl); font-weight: 700; color: var(--color-primary); margin-block: var(--space-xl) var(--space-lg); }
  .advantages-list { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .advantages-list li { font-size: var(--text-base); color: var(--color-text); }
  .info-sidebar { display: flex; flex-direction: column; gap: var(--space-lg); }
  .info-card { background: #f8f9fa; border-radius: var(--radius-lg); padding: var(--space-xl); }
  .info-card--accent { background: var(--color-primary); color: #fff; }
  .info-card h3 { font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-block-end: var(--space-md); }
  .info-card--accent h3 { color: var(--color-accent); }
  .check-list, .check-list-light { list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .check-list li { font-size: var(--text-sm); color: var(--color-text); }
  .check-list li::before { content: "✓ "; color: var(--color-accent); font-weight: 700; }
  .check-list-light li { font-size: var(--text-sm); color: rgba(255,255,255,.9); }
  .check-list-light li::before { content: "• "; color: var(--color-accent); }
</style>
